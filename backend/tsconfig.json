{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "rootDir": "..",
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext"
  },
  "include": ["src/**/*"]
}
